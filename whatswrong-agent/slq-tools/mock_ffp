#!/usr/bin/env python3
from AcqHeaderDefination.SfScanHeader import ACQUISITION_HEADER_TYPE
from AcqHeaderDefination.ScanSysData import EXAM_LEVEL_INFO_TYPE
from inspect_ffp_file import inspect_ffp_file
import argparse
import ctypes
import subprocess
import shutil
import os
import pathlib
import math
import click

def generateOriginScankey(ffp_path: str):
    p = pathlib.Path(ffp_path)
    return p.stem if p.suffix == '.ffp' else p.name

def getExamLevelInfo(blob):
    if len(blob) == ctypes.sizeof(ACQUISITION_HEADER_TYPE):
        try:
            acqhdr = ACQUISITION_HEADER_TYPE.from_buffer_copy(blob)
            exam_level_info = acqhdr.exam_level_info
            return exam_level_info
        except Exception as e:
            print("error on resolve the acqheader blob")
    else:
        print("Size of input blob does NOT match the size of ACQUISITION_HEADER_TYPE")

def getSeriesLevelInfo(blob):
    if len(blob) == ctypes.sizeof(ACQUISITION_HEADER_TYPE):
        try:
            acqhdr = ACQUISITION_HEADER_TYPE.from_buffer_copy(blob)
            series_level_info = acqhdr.series_level_info
            return series_level_info
        except Exception as e:
            print("error on resolve the acqheader blob")
    else:
