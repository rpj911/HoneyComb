class SingleCatCase:
    def __init__(self, cat_filename: str, time: int):
        self.cat_filename = cat_filename
        self.time = time
        self.scankey = get_scankey_from_cat(cat_filename)
        self.rds_client_uuid = None

    def run_multi_times(self):
        cmd = f"drive {self.cat_filename}"
        all_r = 0
        for t in range(self.time):
            print(f"Running catfile {self.cat_filename} for {t + 1}/{self.time}")
            r, err = popen(cmd)
            all_r += r
            if r != 0:
                print(f"Command '{cmd}' failed with return code {r}")
                print(f"Error output: {err}")
            else:
                print(f"Catfile {self.cat_filename} executed successfully")
        return all_r

    def run_single_time(self):
        cmd = f"drive {self.cat_filename}"
        print(f"Running catfile {self.cat_filename}")
        r, err = popen(cmd)
        print(f"Catfile {self.cat_filename} executed {'ok' if r == 0 else 'failed'}")
        return r

def get_scankey_from_cat(cat_filename: str):
    with open(cat_filename, 'r') as cat:
        lines = cat.readlines()
    
    start_idx = None
    for i, line in enumerate(lines):
        if re.search(r'\bstruct\s+scan_key\s*\{', line):
            start_idx = i
            break

    if start_idx is None:
        raise ValueError("scan_key not found in file")

    data_lines = lines[start_idx + 1 : start_idx + 1 + 7]
    values = {}
    patterns = {
        'exam_number': r'int\s+exam_number\s*=\s*(\d+)',
        'scan_number': r'int\s+scan_number\s*=\s*(\d+)',
        'series_number': r'int\s+series_number\s*=\s*(\d+)',
        'suite_id': r'string\s+suite_id\s*=\s*"([^"]+)"',
        'unique_sec': r'int\s+unique_sec\s*=\s*(\d+)',
        'unique_usec': r'int\s+unique_usec\s*=\s*(\d+)',
    }
    for line in data_lines:
        for key, pattern in patterns.items():
            if key not in values:
                match = re.search(pattern, line)
                if match:
                    values[key] = match.group(1)

    required = ['suite_id', 'exam_number', 'series_number', 'scan_number', 'unique_sec', 'unique_usec']
    if not all(k in values for k in required):
        missing = [k for k in required if k not in values]
        raise ValueError(f"Missing fields: {missing}")

    result = f"{values['suite_id']}.{values['exam_number']}.{values['series_number']}.{values['scan_number']}.{values['unique_sec']}.{values['unique_usec']}"
    return result

def get_file_position(log_path: str):
    try:
        return os.path.getsize(log_path)
    except FileNotFoundError:
        return 0

def read_log_increment(log_path: str, start_position: int):
    try:
        with open(log_path, 'r', encoding='utf-8') as f:
            f.seek(start_position)
            inc = f.read()
    except FileNotFoundError:
        return ""
    return inc

def popen(*argv,**kw):
    "Simple command runner returns status and stdout"
    print(f"Executing: {argv}")
    cmd = subprocess.Popen(argv, stdout=subprocess.PIPE, shell=True, universal_newlines=True, **kw)
    stdout,stderr = cmd.communicate()
    r = cmd.wait()
    return r, "" if stderr is None else stderr.strip()

def run_cat_multi_time(cat_filename: str, time: int = 3):
    cmd = f"drive {cat_filename}"
    all_r = 0
    for t in range(time):
        print(f"Running catfile {cat_filename} for {t + 1}/{time}")
        r, err = popen(cmd)
        all_r += r
        if r != 0:
            print(f"Command '{cmd}' failed with return code {r}")
            print(f"Error output: {err}")
        else:
            print(f"Catfile {cat_filename} executed successfully")
    return all_r

def _run_cat_single_time_wrapper(case: SingleCatCase):
    return case.run_single_time()

def run_cat_concurrent(cases: List[SingleCatCase]):
    print(f"Starting {len(cases)} processes to run concurrently")
    all_round_ok = True
    all_round_results = []
    for t in range(cases[0].time):
        print(f"Running {cases[0].cat_filename} and {cases[1].cat_filename} for round {t + 1}/{cases[0].time}")
        all_cat_ok = True
        with ProcessPoolExecutor(max_workers=len(cases)) as executor:
            futures = {
                executor.submit(_run_cat_single_time_wrapper, case): case for case in cases
            }
            results = []
            
            for future in as_completed(futures):
                r = future.result()
                if r != 0:
                    all_cat_ok = False
                results.append(r)
        if not all_cat_ok:
            print(f"At least one cat failed for round {t + 1}/{cases[0].time}")
            all_round_ok = False
        else:
            print(f"All {len(cases)} processes returned successfully for round {t + 1}/{cases[0].time}")
        all_round_results.append(results)
    if not all_round_ok:
        print("At least one round failed")
    else:
        print(f"All {cases[0].time} rounds ok")
    return all_round_results

def run_cat_concurrent_single_time(cases: List[SingleCatCase]):
    print(f"Starting {len(cases)} processes to run concurrently")
    all_cat_ok = True
    with ProcessPoolExecutor(max_workers=len(cases)) as executor:
        futures = {
            executor.submit(_run_cat_single_time_wrapper, case): case for case in cases
        }
        results = []
        
        for future in as_completed(futures):
            r = future.result()
            if r != 0:
                all_cat_ok = False
            results.append(r)
    return sum(results)

def protocol_matches(protocol: str, filter_pattern: str) -> bool:
    if filter_pattern is None:
        return False
    return fnmatch.fnmatch(protocol, filter_pattern)

def analysis_recon_timing_log(target_case: SingleCatCase, lines: List[str], protocol_filter: str = None):
    lines = []
    TTFIs = []
    FPSs = []
    TTLIs = []
    timestamp_request = []
    timestamp_first_image = []
    timestamp_last_image = []
    for new_line in lines:
        if new_line.startswith("##"):
            lines.append(f"{target_case.cat_filename}    Failed:{new_line}\n")
        else:
            elements = [e for e in new_line.split(',') if e]
            if len(elements) != 10:
                lines.append(f"{target_case.cat_filename}    Invalid line: {new_line}\n")
                continue
            
            protocol = elements[0]
            if protocol_matches(protocol, protocol_filter):
                print(f"Skipping line with filtered-out protocol: {protocol}")
                continue
            
            TTFIs.append(float(elements[3]))
            FPSs.append(float(elements[4]))
            TTLIs.append(float(elements[5]))
            timestamp_request.append(float(elements[6]))
            timestamp_first_image.append(float(elements[8]))
            timestamp_last_image.append(float(elements[9]))
            request_time = datetime.datetime.fromtimestamp(float(elements[6]))
            first_image_time = datetime.datetime.fromtimestamp(float(elements[8]))
            last_image_time = datetime.datetime.fromtimestamp(float(elements[9]))
            lines.append(f"{target_case.cat_filename}    Success    Protocol={elements[0]}, TTFI={elements[3]}, FPS={elements[4]}, TTLI={elements[5]}, RequestTime={request_time.strftime('%Y-%m-%d %H:%M:%S.%f')}, FirstImageTime={first_image_time.strftime('%Y-%m-%d %H:%M:%S.%f')}, LastImageTime={last_image_time.strftime('%Y-%m-%d %H:%M:%S.%f')}\n")
    if len(TTFIs) == target_case.time:
        lines.append(f"{target_case.cat_filename}    Average    TTFIs={(sum(TTFIs) / target_case.time):.2f}, FPS={(sum(FPSs) / target_case.time):.2f}, TTLI={(sum(TTLIs) / target_case.time):.2f}\n")
    return lines, TTFIs, FPSs, TTLIs, timestamp_request, timestamp_first_image, timestamp_last_image

