def run_cases_concurrent_multi_times(normal_case: SingleCatCase, hyper_case: SingleCatCase, hyper_protocol: str):
    times = normal_case.time
    lines = []
    TTFIs = []
    FPSs = []
    TTLIs = []
    

    before_pos_ig = get_file_position(ig_obelus_log)
    print(f"Size of ig_obelus_log before running: {before_pos_ig} bytes")

    for t in range(times):
        time.sleep(10)
        print(f"Running {normal_case.cat_filename} and {hyper_case.cat_filename} for round {t + 1}/{times} ...")
        before_pos = get_file_position(recon_timing_log)
        result_sum = run_cat_concurrent_single_time([normal_case, hyper_case])
        if result_sum != 0:
            print("At least one cat file failed")
            return
        after_pos = get_file_position(recon_timing_log)
        if after_pos <= before_pos:
            print("No new line in recon_timing")
            
        
        inc = read_log_increment(recon_timing_log, before_pos)
        new_lines = [line for line in inc.split('\n') if line]
        result_line, TTFI, FPS, TTLI, ts_req, ts_fi, ts_li = analysis_recon_timing_single_time(normal_case, new_lines, hyper_protocol)
        lines.append(result_line)
        if TTFI is not None:
            TTFIs.append(TTFI)
        if FPS is not None:
            FPSs.append(FPS)
        if TTLI is not None:
            TTLIs.append(TTLI)


    if len(TTFIs) == times:
        lines.append(f"{normal_case.cat_filename}    Average    TTFIs={(sum(TTFIs) / times):.2f}, FPS={(sum(FPSs) / times):.2f}, TTLI={(sum(TTLIs) / times):.2f}\n")

    inc_ig = read_log_increment(ig_obelus_log, before_pos_ig)
    new_lines_ig = [line for line in inc_ig.split('\n') if line]
    ig_lines = analysis_ig_obelus_log_single_time(normal_case, hyper_case, new_lines_ig)

    return lines, ig_lines, inc_ig


def main():
    parser = argparse.ArgumentParser(description="Run the cat")
    parser.add_argument("--cat", type=str, help="The cat file of normal cases")
    parser.add_argument("-t", "--time", type=int, default=3, help="Number of times to run the cat (default 3)")
    parser.add_argument("--protocol-filter", type=str, help="Filter out protocols matching this pattern (supports wildcards like *)")
    parser.add_argument("--hyper-cat", help="The cat file of hyper case", type=str)
    parser.add_argument("--debug", action="store_true", help="Enable debug mode and save the incremented log files")

    args = parser.parse_args()
    if not args.cat:
        print("Please specify a normal cat file using --cat")
        return -1
    if not args.hyper_cat or not os.path.exists(args.hyper_cat):
        print("Please specify a valid hyper cat file using --hyper-cat")
        return -1
    hyper_case = SingleCatCase(args.hyper_cat, args.time)
    matched_cats = glob.glob(args.cat)
    if not matched_cats:
        print(f"No files matching '{args.cat}' found. Check your dir, now in {os.getcwd()}")
        return -1
    print(f"Found {len(matched_cats)} catfiles match {args.cat}")

    if args.protocol_filter:
        print(f"Protocol filter (excluded): {args.protocol_filter}")

    all_lines = []
    cat_id = 1
    for cat_filename in matched_cats:
        print(f"Ongoing {cat_id}/{len(matched_cats)}: {cat_filename}")
        normal_case = SingleCatCase(cat_filename, args.time)
        new_lines, ig_obelus_rds_lines, ig_obelus_lines = run_cases_concurrent_multi_times(normal_case, hyper_case, args.protocol_filter)
        if len(new_lines) >= 1:
            all_lines.extend(new_lines)
        cat_id += 1
        print(f"{cat_filename} done")
        if args.debug:
            cat_path = pathlib.Path(cat_filename)
            with open(f"{cat_path.stem}_ig_obelus_increment_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}.log", 'w', encoding='utf-8') as f:
                f.write(ig_obelus_lines)
            with open(f"{cat_path.stem}_ig_obelus_rds_increment_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}.log", 'w', encoding='utf-8') as f:
                f.writelines(ig_obelus_rds_lines)
            print(f"DEBUG: Ig obelus incremented log saved to {cat_path.stem}_ig_obelus_incremented_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}.log")
        print("----------------------------------------")
    if len(all_lines) == 0:
        print("No new lines for recon timing")
        return -1
    timing_log_name = f"/usr/g/service/log/recon_timing_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}.log"
    with open(timing_log_name, 'w', encoding='utf-8') as f:
        f.writelines(all_lines)
    print(f"Recon timing results saved to {timing_log_name}")

if __name__ == "__main__":
    main()